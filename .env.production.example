# Medusa Backend
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.distribuidorasicaru.com

# Site URL (canonical, used for SEO/sitemap/schema)
NEXT_PUBLIC_SITE_URL=https://distribuidorasicaru.com

# ISR Revalidation (generate with: openssl rand -hex 32)
REVALIDATION_SECRET=

# MeiliSearch (public search-only key — safe to expose)
NEXT_PUBLIC_MEILISEARCH_HOST=https://search-sicaru.up.railway.app
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=

# MercadoPago (public key)
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=

# Sentry (error tracking)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=sicaru
SENTRY_PROJECT=storefront
